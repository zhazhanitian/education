# 数据库连接（本地开发，Docker 启动的 postgres 默认值）
DATABASE_URL="postgresql://edu_user:your_postgres_password@localhost:5432/edu_platform"

# JWT 密钥（本地随意填，生产必须改）
JWT_SECRET="local-dev-jwt-secret"

# 初始管理员（仅首次 pnpm db:seed 时生效，账号已存在则跳过）
INIT_ADMIN_USERNAME="admin"
INIT_ADMIN_PASSWORD="your_admin_password"

# 文件上传目录（留空则默认 ./public/uploads）
# UPLOAD_DIR=./public/uploads
