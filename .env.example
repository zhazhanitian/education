# 数据库配置
POSTGRES_DB=edu_platform
POSTGRES_USER=edu_user
POSTGRES_PASSWORD=change_me_strong_password    # 生产环境必须修改

# JWT 密钥（生产环境必须修改，建议 openssl rand -hex 32 生成）
JWT_SECRET=change_me_jwt_secret_at_least_32_chars

# 初始超级管理员（仅首次 db:seed 时生效，账号已存在则跳过）
# 部署后请立即登录修改密码，之后可从 .env 中删除这两行
INIT_ADMIN_USERNAME=admin
INIT_ADMIN_PASSWORD=change_me_strong_password

# 对外端口
HTTP_PORT=80
